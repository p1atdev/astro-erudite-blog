{
	"name": "astro-erudite",
	"type": "module",
	"version": "1.6.2",
	"private": true,
	"scripts": {
		"dev": "astro dev",
		"start": "astro dev",
		"build": "git submodule update --remote && astro check && astro build",
		"preview": "astro preview",
		"astro": "astro",
		"postinstall": "patch-package",
		"lint": "oxlint",
		"format": "prettier --write **/*.{ts,tsx,css,astro} --ignore-path .gitignore",
		"new:article": "bun run --bun ./utils/new-article.ts"
	},
	"dependencies": {
		"@astrojs/check": "0.9.9",
		"@astrojs/markdown-remark": "7.2.0",
		"@astrojs/mdx": "7.0.0",
		"@astrojs/react": "6.0.0",
		"@astrojs/rss": "4.0.18",
		"@astrojs/sitemap": "^3.7.3",
		"@expressive-code/plugin-collapsible-sections": "^0.43.1",
		"@expressive-code/plugin-line-numbers": "^0.43.1",
		"@fontsource-variable/red-hat-text": "^5.2.8",
		"@fontsource/ibm-plex-sans-jp": "^5.2.8",
		"@iconify-json/lucide": "^1.2.113",
		"@iconify-json/simple-icons": "^1.2.86",
		"@radix-ui/react-dialog": "^1.1.17",
		"@radix-ui/react-popover": "^1.1.17",
		"@radix-ui/react-tooltip": "^1.2.10",
		"@swup/astro": "^1.8.0",
		"@tailwindcss/vite": "^4.3.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vercel/og": "^0.11.1",
		"astro": "7.0.2",
		"astro-embed": "^0.13.0",
		"astro-expressive-code": "^0.43.1",
		"astro-icon": "^1.1.5",
		"astro-pagefind": "^2.0.0",
		"budoux": "^0.8.4",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"hastscript": "^9.0.1",
		"lucide-react": "^1.20.0",
		"patch-package": "^8.0.1",
		"radix-ui": "^1.6.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-document": "^7.0.3",
		"rehype-external-links": "^3.0.0",
		"rehype-katex": "^7.0.1",
		"rehype-pretty-code": "^0.14.3",
		"remark-emoji": "^5.0.2",
		"remark-math": "^6.0.0",
		"satori": "^0.26.0",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.3",
		"unist-util-visit": "^5.1.0"
	},
	"devDependencies": {
		"@iconify-json/ri": "^1.2.10",
		"@iconify-json/tabler": "^1.2.35",
		"@pagefind/default-ui": "^1.5.2",
		"@types/bun": "^1.3.14",
		"eslint-plugin-oxlint": "^1.70.0",
		"oxlint": "^1.70.0",
		"prettier": "^3.8.4",
		"prettier-plugin-astro": "^0.14.1",
		"prettier-plugin-astro-organize-imports": "^0.4.12",
		"prettier-plugin-tailwindcss": "^0.8.0"
	},
	"prettier": {
		"semi": true,
		"singleQuote": false,
		"plugins": [
			"prettier-plugin-astro",
			"prettier-plugin-tailwindcss",
			"prettier-plugin-astro-organize-imports"
		],
		"overrides": [
			{
				"files": "*.astro",
				"options": {
					"parser": "astro"
				}
			}
		]
	}
}